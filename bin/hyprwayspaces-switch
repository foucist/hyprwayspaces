#!/usr/bin/env bash
# Switch the active context, step within the current workspace row,
# or open the scratchpad.
#
# Usage:
#   hyprwayspaces-switch up | down              cycle contexts (capped at a / e)
#   hyprwayspaces-switch left | right           step workspace -1 / +1 (clamped 1..10)
#   hyprwayspaces-switch <a-e>                  switch to context, land on workspace 1
#   hyprwayspaces-switch <a-e>-<1..10>          switch and land on a specific workspace
#   hyprwayspaces-switch <a-e>-s                switch and toggle the scratchpad
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
STATE_FILE="$REPO_ROOT/generated/current-context"
LABEL_FILE="$HOME/.config/hyprwayspaces/current-context-label"
NAMES_FILE="$REPO_ROOT/generated/context-names.json"

usage() {
    sed -n '2,10p' "$0" | sed 's/^# \?//'
    exit "${1:-1}"
}

arg="${1:-}"
[[ -n "$arg" ]] || usage

current=$(cat "$STATE_FILE" 2>/dev/null || echo "a")

context_label() {
    local ctx="$1"
    local name=""
    if [[ -f "$NAMES_FILE" ]]; then
        name=$(jq -r --arg c "$ctx" '.[$c] // ""' "$NAMES_FILE" 2>/dev/null || true)
    fi
    [[ -n "$name" ]] && printf '%s\n' "$name" || printf '%s\n' "$ctx"
}

# Default landing workspace: keep the user on their current numeric workspace
# when cycling contexts. Falls back to 1 when active workspace isn't numeric
# (e.g. they're sitting on a scratchpad).
active_ws=$(hyprctl activeworkspace -j | jq -r '.name')
if [[ "$active_ws" =~ ^[0-9]+$ ]]; then
    target_ws="$active_ws"
else
    target_ws=1
fi
toggle_scratchpad=false

case "$arg" in
    up)
        case "$current" in
            a|b) ctx="a" ;;
            c) ctx="b" ;;
            d) ctx="c" ;;
            e) ctx="d" ;;
            *)   ctx="a" ;;
        esac
        ;;
    down)
        case "$current" in
            a) ctx="b" ;;
            b) ctx="c" ;;
            c) ctx="d" ;;
            d|e) ctx="e" ;;
            *)   ctx="a" ;;
        esac
        ;;
    left|right)
        # Step workspace within the current context. Clamp at 1..10. Skip when
        # not on a numeric (context-owned) workspace.
        active=$(hyprctl activeworkspace -j | jq -r '.name')
        [[ "$active" =~ ^[0-9]+$ ]] || exit 0
        if [[ "$arg" == "right" ]]; then
            (( active < 10 )) || exit 0
            hyprctl dispatch workspace "name:$((active + 1))" >/dev/null
        else
            (( active > 1 )) || exit 0
            hyprctl dispatch workspace "name:$((active - 1))" >/dev/null
        fi
        exit 0
        ;;
    [a-e])
        ctx="$arg"
        ;;
    [a-e]-s)
        ctx="${arg:0:1}"
        toggle_scratchpad=true
        ;;
    [a-e]-[0-9]|[a-e]-10)
        ctx="${arg:0:1}"
        target_ws="${arg:2}"
        if (( target_ws < 1 || target_ws > 10 )); then
            notify-send -u critical "hyprwayspaces-switch" "workspace must be 1-10 (got: $target_ws)"
            exit 1
        fi
        ;;
    *)
        notify-send -u critical "hyprwayspaces-switch" "Invalid argument: $arg"
        exit 1
        ;;
esac

mkdir -p "$(dirname "$STATE_FILE")"

if [[ "$current" != "$ctx" ]]; then
    target_label=$(context_label "$ctx")

    # Snapshot focused window per workspace before we wreck hyprland's
    # focus history by moving windows around.
    "$REPO_ROOT/bin/hyprwayspaces-state" save "$current"

    # Build a single hyprctl --batch command for ALL the moves (hide current +
    # show target). With master:new_status=slave the master window must be
    # moved first (top-left in position order), so sort ascending by (y, x).
    # One IPC round-trip = much less visible relayout jank than N moves.
    clients_json=$(hyprctl clients -j)
    batch=$(jq -r --arg cur "$current" --arg new "$ctx" '
        (
            [.[] | select(.workspace.name | test("^[0-9]+$"))]
            | sort_by([.at[1], .at[0]])
            | map("dispatch movetoworkspacesilent name:_\($cur)-\(.workspace.name),address:\(.address)")
        ) + (
            [.[] | select(.workspace.name | startswith("_\($new)-"))]
            | sort_by([.at[1], .at[0]])
            | map("dispatch movetoworkspacesilent name:\(.workspace.name | sub("^_\($new)-"; "")),address:\(.address)")
        )
        | join(" ; ")
    ' <<<"$clients_json")

    [[ -n "$batch" ]] && hyprctl --batch "$batch" >/dev/null

    echo -n "$ctx" > "$STATE_FILE"
    mkdir -p "$(dirname "$LABEL_FILE")"
    printf '%s\n' "$target_label" > "$LABEL_FILE"
    pkill -SIGRTMIN+11 waybar 2>/dev/null || true
    hyprctl reload >/dev/null
fi

hyprctl dispatch workspace "name:${target_ws}" >/dev/null

# Re-focus the window that was focused in this workspace before the swap,
# and warp the cursor to it. No-op if there's no saved state yet.
"$REPO_ROOT/bin/hyprwayspaces-state" restore "$target_ws" "$ctx" 2>/dev/null || true

if [[ "$toggle_scratchpad" == true ]]; then
    hyprctl dispatch togglespecialworkspace "scratch-${ctx}" >/dev/null
fi
